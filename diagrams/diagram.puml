@startuml

!define C4Container https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include C4Container

skinparam svgLinkTarget foo

System_Boundary(c1, "edx-platform: edx-redfid", $link="https://github.com/eol-uchile/edx-redfid") {
    System_Boundary(c2, "requirements", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/requirements/") {
        
            System_Boundary(apis, "apis", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/requirements/apis.txt") {
            
                Container(apis1, "redfid_edx_api", $link="https://github.com/cmmedu/redfid-edx-api.git/releases/tag/v1.1.0")
            
            }
        
            System_Boundary(apps, "apps", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/requirements/apps.txt") {
            
                Container(apps1, "redfid_oauth2", $link="https://github.com/cmmedu/redfid_oauth2/releases/tag/v1.0.0")
            
                Container(apps2, "eol_duplicate_xblock", $link="https://github.com/eol-uchile/eol_duplicate_xblock/releases/tag/1.0.0")
            
                Container(apps3, "eol_jump_to", $link="https://github.com/eol-uchile/eol_jump_to/commit/bdbb1fca8ae0e0e7e8d6c38641975942ea9f154e")
            
            }
        
            System_Boundary(python_packages, "python_packages", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/requirements/python_packages.txt") {
            
                Container(python_packages1, "django-redis")
            
                Container(python_packages2, "fluent-logger")
            
                Container(python_packages3, "python-json-logger")
            
            }
        
            System_Boundary(reports, "reports", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/requirements/reports.txt") {
            
                Container(reports1, "cmmedu_seguimiento", $link="https://github.com/cmmedu/cmmedu-seguimiento/releases/tag/v1.2.1")
            
            }
        
            System_Boundary(tabs_plugins, "tabs_plugins", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/requirements/tabs_plugins.txt") {
            
                Container(tabs_plugins1, "eol_completion", $link="https://github.com/eol-uchile/eol_completion/commit/30303bc4c2195789093e4b634e8ebe5fa639981a")
            
            }
        
            System_Boundary(xblocks, "xblocks", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/requirements/xblocks.txt") {
            
                Container(xblocks1, "iaa-xblock", $link="https://github.com/cmmedu/iaa-xblock/releases/tag/v0.0.1")
            
                Container(xblocks2, "iterative-xblock", $link="https://github.com/cmmedu/iterative-xblock.git/commit/55549592fabcb4962b93682f6fc4379f0332503b")
            
                Container(xblocks3, "ora2", $link="https://github.com/eol-uchile/edx-ora2.git/commit/81fdd8c46e3abb1a4dda17f946e0b12d181a2078")
            
                Container(xblocks4, "edx-sga", $link="https://github.com/eol-uchile/edx-sga/commit/ee43f7993e6a81626fc3a4666cfa09fe3c2140cb")
            
                Container(xblocks5, "scormxblock", $link="https://github.com/eol-uchile/edx_xblock_scorm/commit/c23184c0e22a7847f0b0c917bbe431c2973770fb")
            
                Container(xblocks6, "eolconditional-xblock", $link="https://github.com/eol-uchile/eol-conditional-xblock.git/commit/725b8eac92418a70b5a5081e953539477f459a60")
            
                Container(xblocks7, "eolcontainer-xblock", $link="https://github.com/eol-uchile/eol-container-xblock/releases/tag/v1.1.0")
            
                Container(xblocks8, "dialogsquestionsxblock-xblock", $link="https://github.com/eol-uchile/eol-dialogs-question-xblock/commit/6d866ffef7fb7b6f34a37670ac4d84715b921675")
            
                Container(xblocks9, "eoldialogs-xblock", $link="https://github.com/eol-uchile/eol-dialogs-xblock.git/commit/6d34c0e1be2519fc83cb75a9af2d78783d03dd24")
            
                Container(xblocks10, "eolpersistenttab-xblock", $link="https://github.com/eol-uchile/eol-persistent-tab-xblock/commit/2f345b925211d5698fa05a37c09e39b583e4bd48")
            
                Container(xblocks11, "eolquestion-xblock", $link="https://github.com/eol-uchile/eol-question-xblock.git/commit/035d1eaca888d16c2c28f3ac28b985bd4cac74b0")
            
                Container(xblocks12, "vof-xblock", $link="https://github.com/eol-uchile/eol-vof-xblock.git/commit/aa28eb44ff03a4243cee1d814e32cd4b5fc1f972")
            
                Container(xblocks13, "eol_list_grade", $link="https://github.com/eol-uchile/eol_list_grade/commit/0d7688919bad8b229bff2948f31fedd76f1029d2")
            
                Container(xblocks14, "flow-control-xblock", $link="https://github.com/eol-uchile/flow-control-xblock/commit/4e275efba4e37d9371a27df4997c692c0b40d281")
            
                Container(xblocks15, "free-text-response", $link="https://github.com/eol-uchile/free-text-response/commit/eec58e583bde6aa5098230e4c74a1e59fb9f7702")
            
                Container(xblocks16, "pdf-xblock", $link="https://github.com/eol-uchile/pdfXBlock/commit/1ef65825dfcffbaa4aeec32451f4d495a78ab87c")
            
                Container(xblocks17, "xblock-drag-and-drop-v2", $link="https://github.com/eol-uchile/xblock-drag-and-drop-v2/commit/58d8a691cf9210220925f3d2957b39a377f6704c")
            
                Container(xblocks18, "xblock_in_video_quiz", $link="https://github.com/eol-uchile/xblock-in-video-quiz/commit/1555dcbd96341f19b76f915f0135f46192869796")
            
            }
        
    }

    System_Boundary(theme, "Themes", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/themes/") {
        
            Container(theme1, "redfid-theme", $link="https://github.com/eol-uchile/redfid-theme")
        
    }

    System_Boundary(dockerfile, "edx-platform base", $link="https://github.com/eol-uchile/edx-redfid/blob/vlabx-release/koa/Dockerfile") {
            Container(dk, "koa", $link="https://ghcr.io/eol-virtuallabx/edx-platform:koa")
    }
}

SHOW_LEGEND()

@enduml